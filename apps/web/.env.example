DATABASE_URL=postgresql://korrali:PASSWORD@localhost:5432/growth_uat

NEXTAUTH_URL=https://growth-uat.korrali.com
# Used for session signing AND unsubscribe token HMAC
NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RESEND_API_KEY=
# Transactional/internal email (auth magic links, founder notifications)
EMAIL_FROM=Korrali Growth <growth@korrali.com>
# Cold outbound — subdomain keeps korrali.com root domain reputation clean
GROWTH_FROM_NAME=Ashish from Korrali
GROWTH_FROM_EMAIL=ashish@outreach.korrali.com
# Inbound replies (MX for reply.outreach.korrali.com → Resend inbound servers)
RESEND_INBOUND_DOMAIN=reply.outreach.korrali.com
RESEND_WEBHOOK_SECRET=

# AI model routing (all default to Haiku; upgrade individual slots by changing env var)
# Start here at week 1, then ramp: BULK_MODEL=claude-sonnet-4-6 after volume proves out
BULK_MODEL=
WRITING_MODEL=
HIGH_INTENT_MODEL=
ANTHROPIC_API_KEY=

# Safety — ramp MAX_SENDS_PER_DAY slowly: start at 10 for first week
MAX_SENDS_PER_DAY=20
MAX_SENDS_PER_DOMAIN_PER_DAY=1
SEND_WINDOW_START_HOUR=8
SEND_WINDOW_END_HOUR=18
SEND_TIMEZONE=America/New_York
QUIET_HOURS_START=20
QUIET_HOURS_END=8

FOUNDER_EMAIL=bhagat.ashish.a@gmail.com
APP_URL=https://growth-uat.korrali.com

# ─── Monitoring (GlitchTip self-hosted at glitchtip.korrali.com) ──────────────
SENTRY_DSN=https://PUBLIC_KEY@glitchtip.korrali.com/PROJECT_ID
NEXT_PUBLIC_SENTRY_DSN=https://PUBLIC_KEY@glitchtip.korrali.com/PROJECT_ID
SENTRY_ORG=korrali
SENTRY_PROJECT=growth-web
